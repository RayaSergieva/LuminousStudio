@model LuminousStudio.Web.ViewModels.TiffanyLamp.TiffanyLampDeleteVM

@{
    ViewData["Title"] = "Delete Lamp";
}

<div class="container mt-4">
    <div class="card shadow-sm border-danger mx-auto" style="max-width: 600px;">
        <div class="card-header bg-danger text-white">
            <h3 class="mb-0">Delete Tiffany Lamp</h3>
        </div>
        <div class="card-body">
            <h5 class="text-danger mb-4">Are you sure you want to delete this lamp?</h5>

            <div class="text-center mb-3">
                <img src="@Model.Picture" alt="@Model.TiffanyLampName"
                     class="img-thumbnail" style="max-height: 150px;" />
            </div>

            <dl class="row">
                <dt class="col-sm-4">Name:</dt>
                <dd class="col-sm-8">@Model.TiffanyLampName</dd>

                <dt class="col-sm-4">Manufacturer:</dt>
                <dd class="col-sm-8">@Model.ManufacturerName</dd>

                <dt class="col-sm-4">Style:</dt>
                <dd class="col-sm-8">@Model.LampStyleName</dd>

                <dt class="col-sm-4">Price:</dt>
                <dd class="col-sm-8">$@Model.Price.ToString("0.00")</dd>

                <dt class="col-sm-4">Quantity:</dt>
                <dd class="col-sm-8">@Model.Quantity</dd>
            </dl>

            <form asp-action="Delete">
                <input type="hidden" asp-for="Id" />
                <div class="d-flex gap-2 mt-4">
                    <button type="submit" class="btn btn-danger">
                        <i class="bi bi-trash"></i> Confirm Delete
                    </button>
                    <a asp-area="Admin" asp-controller="LampManagement"
                           asp-action="Index" class="btn btn-outline-secondary">
                        <i class="bi bi-arrow-left"></i> Back to List
                    </a>
                </div>
            </form>
        </div>
    </div>
</div>