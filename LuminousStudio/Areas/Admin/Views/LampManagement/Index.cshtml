@model IEnumerable<LampManagementIndexVM>

@{
    ViewData["Title"] = "Manage Lamps";
}

<div class="container mt-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="fw-bold">Manage Tiffany Lamps</h1>
        <div class="d-flex gap-2">
            <a asp-area="Admin" asp-controller="LampManagement" asp-action="Create"
                   class="btn btn-success">
                <i class="bi bi-plus-circle"></i> Add New Lamp
            </a>
            <a asp-area="Admin" asp-controller="Home" asp-action="Index"
                   class="btn btn-secondary">
                <i class="bi bi-arrow-left"></i> Back to Dashboard
            </a>
        </div>
    </div>

    <div class="card shadow border-0">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-striped table-hover mb-0">
                    <thead class="table-dark">
                        <tr>
                            <th>Image</th>
                            <th>Name</th>
                            <th>Manufacturer</th>
                            <th>Style</th>
                            <th>Price</th>
                            <th>Discount</th>
                            <th>Quantity</th>
                            <th class="text-center">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var lamp in Model)
                        {
                            <tr class="align-middle">
                                <td>
                                    <img src="@lamp.Picture" alt="@lamp.TiffanyLampName"
                                         style="width: 60px; height: 60px; object-fit: cover;"
                                         class="rounded" />
                                </td>
                                <td>@lamp.TiffanyLampName</td>
                                <td>@lamp.ManufacturerName</td>
                                <td>@lamp.LampStyleName</td>
                                <td>$@lamp.Price.ToString("0.00")</td>
                                <td>
                                    @if (lamp.Discount > 0)
                                    {
                                        <span class="badge bg-success">@lamp.Discount.ToString("0.00")%</span>
                                    }
                                    else
                                    {
                                        <span class="text-muted">None</span>
                                    }
                                </td>
                                <td>@lamp.Quantity</td>
                                <td class="text-center">
                                    <div class="d-flex gap-1 justify-content-center">
                                        <a asp-area="Admin" asp-controller="LampManagement"
                                               asp-action="Edit" asp-route-id="@lamp.Id"
                                               class="btn btn-sm btn-outline-primary">
                                            <i class="bi bi-pencil"></i>
                                        </a>
                                        <a asp-area="Admin" asp-controller="LampManagement"
                                               asp-action="Delete" asp-route-id="@lamp.Id"
                                               class="btn btn-sm btn-outline-danger">
                                            <i class="bi bi-trash"></i>
                                        </a>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>