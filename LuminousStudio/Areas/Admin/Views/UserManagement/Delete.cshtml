@model UserDeleteVM

@{
    ViewData["Title"] = "Delete User";
}

<div class="container mt-5">
    <div class="card shadow border-danger border-0 mx-auto" style="max-width: 600px;">
        <div class="card-header bg-danger text-white">
            <h3 class="mb-0">Delete Client</h3>
        </div>
        <div class="card-body">
            <h5 class="text-danger mb-4">Are you sure you want to delete this client?</h5>

            <dl class="row">
                <dt class="col-sm-4">Username:</dt>
                <dd class="col-sm-8">@Model.UserName</dd>

                <dt class="col-sm-4">First Name:</dt>
                <dd class="col-sm-8">@Model.FirstName</dd>

                <dt class="col-sm-4">Last Name:</dt>
                <dd class="col-sm-8">@Model.LastName</dd>

                <dt class="col-sm-4">Email:</dt>
                <dd class="col-sm-8">@Model.Email</dd>

                <dt class="col-sm-4">Address:</dt>
                <dd class="col-sm-8">@Model.Address</dd>
            </dl>

            @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
            {
                <div class="alert alert-danger">@error.ErrorMessage</div>
            }

            <form asp-action="Delete" method="post">
                <input type="hidden" asp-for="Id" />
                <div class="d-flex gap-2 mt-4">
                    <button type="submit" class="btn btn-danger">
                        <i class="bi bi-trash"></i> Confirm Delete
                    </button>
                    <a asp-area="Admin" asp-controller="UserManagement"
                           asp-action="Index" class="btn btn-outline-secondary">
                        <i class="bi bi-arrow-left"></i> Back
                    </a>
                </div>
            </form>
        </div>
    </div>
</div>