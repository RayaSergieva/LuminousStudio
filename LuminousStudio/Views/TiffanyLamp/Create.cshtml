@model LuminousStudio.Web.ViewModels.TiffanyLamp.TiffanyLampCreateVM

@{
    ViewData["Title"] = "Create";
}

<div class="container mt-4">
    <div class="card shadow-sm">
        <div class="card-header bg-primary text-white">
            <h3 class="mb-0"><i class="bi bi-plus-circle-fill"></i> Create Tiffany Lamp</h3>
        </div>
        <div class="card-body">
            <form asp-action="Create">
                <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

                <div class="mb-3">
                    <label asp-for="TiffanyLampName" class="form-label">Tiffany Lamp Name</label>
                    <input asp-for="TiffanyLampName" class="form-control" />
                    <span asp-validation-for="TiffanyLampName" class="text-danger small"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="ManufacturerId" class="form-label">Manufacturer</label>
                    <select asp-for="ManufacturerId" class="form-select">
                        @foreach (var manufacturer in Model.Manufacturers)
                        {
                            <option value="@manufacturer.Id">@manufacturer.Name</option>
                        }
                    </select>
                    <span asp-validation-for="ManufacturerId" class="text-danger small"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="LampStyleId" class="form-label">Lamp Style</label>
                    <select asp-for="LampStyleId" class="form-select">
                        @foreach (var lampStyle in Model.LampStyles)
                        {
                            <option value="@lampStyle.Id">@lampStyle.Name</option>
                        }
                    </select>
                    <span asp-validation-for="LampStyleId" class="text-danger small"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Picture" class="form-label">Picture URL</label>
                    <input asp-for="Picture" class="form-control" />
                    <span asp-validation-for="Picture" class="text-danger small"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Quantity" class="form-label">Quantity</label>
                    <input asp-for="Quantity" class="form-control" />
                    <span asp-validation-for="Quantity" class="text-danger small"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Price" class="form-label">Price</label>
                    <input asp-for="Price" class="form-control" />
                    <span asp-validation-for="Price" class="text-danger small"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Discount" class="form-label">Discount (%)</label>
                    <input asp-for="Discount" class="form-control" />
                    <span asp-validation-for="Discount" class="text-danger small"></span>
                </div>

                <div class="d-flex justify-content-between mt-4">
                    <button type="submit" class="btn btn-success">
                        <i class="bi bi-check-circle"></i> Create
                    </button>
                    <a asp-action="Index" class="btn btn-secondary">
                        <i class="bi bi-arrow-left-circle"></i> Back to List
                    </a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}