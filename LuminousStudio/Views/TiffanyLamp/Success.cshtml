@{
    ViewData["Title"] = "Success";
}

<div class="container mt-5">
    <div class="alert alert-success shadow-sm text-center" role="alert">
        <h4 class="alert-heading"><i class="bi bi-check-circle-fill"></i> Tiffany Lamp Removed</h4>
        <p class="mb-0">You successfully removed a Tiffany Lamp from the list.</p>
    </div>

    <div class="text-center mt-4">
        <a asp-action="Index" class="btn btn-outline-primary">
            <i class="bi bi-arrow-left-circle"></i> Back to List
        </a>
    </div>
</div>