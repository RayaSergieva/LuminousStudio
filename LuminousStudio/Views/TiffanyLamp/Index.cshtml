@model IEnumerable<LuminousStudio.Models.TiffanyLamp.TiffanyLampIndexVM>

@{
    ViewData["Title"] = "Tiffany Lamps";
    ViewData["BodyClass"] = "tiffanylamps-page";
}

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css" />
<link rel="stylesheet" href="~/css/tiffanylamps.css" />

<div class="container py-5 mt-5 position-relative" style="z-index: 1;">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="display-5 text-white">Tiffany Lamps</h1>
        @if (User.Identity.IsAuthenticated && User.IsInRole("Administrator"))
        {
            <a asp-action="Create" class="btn btn-primary">+ Create New</a>
        }
    </div>

    <form asp-controller="TiffanyLamp" asp-action="Index" method="get" class="row g-3 mb-4">
        <div class="col-md-4">
            <input type="text" name="SearchStringManufacturerName" class="form-control" placeholder="Search by Manufacturer" />
        </div>
        <div class="col-md-4">
            <input type="text" name="SearchStringLampStyleName" class="form-control" placeholder="Search by Lamp Style" />
        </div>
        <div class="col-md-4 d-grid">
            <input type="submit" value="Filter" class="btn btn-outline-light" />
        </div>
    </form>

    <div class="row row-cols-1 row-cols-md-3 g-4">
        @foreach (var item in Model)
        {
            <div class="col">
                <div class="card h-100 shadow-sm tiffany-card">
                    <img src="@item.Picture" class="card-img-top" alt="@item.TiffanyLampName" style="height: 300px; object-fit: cover;">
                    <div class="lamp-name-box text-center">
                        @item.TiffanyLampName
                    </div>

                    <div class="card-body">
                        <p class="card-text mb-1">
                            <strong>Manufacturer:</strong> @item.ManufacturerName<br />
                            <strong>Style:</strong> @item.LampStyleName<br />
                            <strong>Price:</strong> $@item.Price<br />
                            <strong>Quantity:</strong> @item.Quantity
                        </p>
                        @if (item.Discount > 0)
                        {
                            <span class="badge bg-success">Discount: @item.Discount.ToString("0.00")%</span>
                        }
                    </div>
                    <div class="card-footer border-top-0 bg-transparent">
                        <div class="d-flex flex-wrap gap-2">
                            <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-success btn-sm">Details</a>

                            @if (User.Identity.IsAuthenticated)
                            {
                                <a asp-action="Add" asp-controller="ShoppingCart" asp-route-tiffanyLampId="@item.Id" class="btn btn-warning btn-sm d-flex align-items-center gap-1">
                                    Add to Cart
                                    <i class="bi bi-cart-fill"></i>
                                </a>
                            }

                            @if (User.Identity.IsAuthenticated && User.IsInRole("Administrator"))
                            {
                                <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-outline-primary btn-sm">Edit</a>
                                <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-outline-danger btn-sm">Delete</a>
                            }
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}