@model LuminousStudio.Models.TiffanyLamp.TiffanyLampDetailsVM

@{
    ViewData["Title"] = "Details";
}

<div class="container mt-4">
    <div class="card shadow-sm">
        <div class="card-header bg-dark text-white">
            <h2 class="mb-0">@Model.TiffanyLampName</h2>
        </div>
        <div class="card-body">
            <div class="row mb-3">
                <div class="col-md-4 text-center">
                    <img src="@Model.Picture" class="img-fluid rounded border" alt="Lamp Image" style="max-height: 200px;" />
                </div>
                <div class="col-md-8">
                    <table class="table table-borderless table-sm">
                        <tbody>
                            <tr>
                                <th scope="row">Manufacturer</th>
                                <td>@Model.ManufacturerName</td>
                            </tr>
                            <tr>
                                <th scope="row">Manufacturer ID</th>
                                <td>@Model.ManufacturerId</td>
                            </tr>
                            <tr>
                                <th scope="row">Lamp Style</th>
                                <td>@Model.LampStyleName</td>
                            </tr>
                            <tr>
                                <th scope="row">Lamp Style ID</th>
                                <td>@Model.LampStyleId</td>
                            </tr>
                            <tr>
                                <th scope="row">Quantity</th>
                                <td><span class="badge bg-primary">@Model.Quantity</span></td>
                            </tr>
                            <tr>
                                <th scope="row">Price</th>
                                <td><span class="text-success fw-bold">@Model.Price.ToString("C")</span></td>
                            </tr>
                            <tr>
                                <th scope="row">Discount</th>
                                <td><span class="badge bg-warning text-dark">@Model.Discount %</span></td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </div>

            <div class="d-flex justify-content-between mt-4">
                <a class="btn btn-outline-primary" asp-action="Edit" asp-route-id="@Model.Id">
                    <i class="bi bi-pencil-square"></i> Edit
                </a>
                <a class="btn btn-secondary" asp-action="Index">
                    <i class="bi bi-arrow-left-circle"></i> Back to List
                </a>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}