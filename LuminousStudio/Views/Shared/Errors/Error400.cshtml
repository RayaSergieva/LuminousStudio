@{
    ViewData["Title"] = "Bad Request";
    Layout = "/Views/Shared/_Layout.cshtml";
}

<div class="container text-center mt-5">
    <div class="py-5">
        <i class="bi bi-exclamation-triangle-fill text-warning" style="font-size: 5rem;"></i>
        <h1 class="display-1 fw-bold text-warning mt-3">400</h1>
        <h2 class="mb-4">Bad Request</h2>
        <p class="lead text-muted mb-4">
            The request could not be understood by the server due to malformed syntax.
        </p>
        <a asp-area="" asp-controller="Home" asp-action="Index" class="btn btn-primary btn-lg">
            <i class="bi bi-house"></i> Back to Home
        </a>
    </div>
</div>