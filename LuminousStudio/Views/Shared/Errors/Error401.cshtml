@{
    ViewData["Title"] = "Unauthorized";
    Layout = "/Views/Shared/_Layout.cshtml";
}

<div class="container text-center mt-5">
    <div class="py-5">
        <i class="bi bi-lock-fill text-warning" style="font-size: 5rem;"></i>
        <h1 class="display-1 fw-bold text-warning mt-3">401</h1>
        <h2 class="mb-4">Unauthorized</h2>
        <p class="lead text-muted mb-4">
            You need to be logged in to access this page.
        </p>
        <div class="d-flex justify-content-center gap-3">
            <a asp-area="Identity" asp-page="/Account/Login" class="btn btn-primary btn-lg">
                <i class="bi bi-box-arrow-in-right"></i> Login
            </a>
            <a asp-area="" asp-controller="Home" asp-action="Index"
                   class="btn btn-outline-secondary btn-lg">
                <i class="bi bi-house"></i> Back to Home
            </a>
        </div>
    </div>
</div>