<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - LuminousStudio</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/tiffanylamps.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/LuminousStudio.styles.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.3/font/bootstrap-icons.css" />

    @RenderSection("Styles", required: false)

    <style>
            .navbar.glass {
                background-color: rgba(0, 0, 0, 0.75) !important;
                backdrop-filter: blur(10px);
                border-bottom: 1px solid rgba(255, 255, 255, 0.1);
            }

            .dropdown .btn {
                background-color: rgba(255, 255, 255, 0.1);
                border: 1px solid rgba(255, 255, 255, 0.2);
            }

            html, body {
                height: 100%;
            }

            body {
                display: flex;
                flex-direction: column;
                min-height: 100vh;
                padding-top: 80px;
            }

            .container {
                flex: 1;
            }

            .footer {
                background-color: rgba(0, 0, 0, 0.75);
                margin-top: auto;
            }

            form.logout-form {
                display: inline;
            }
    </style>
</head>
<body class="@ViewData["BodyClass"]">
    <header>
        <nav class="navbar navbar-expand-sm navbar-dark fixed-top glass shadow">
            <div class="container-fluid">
                <a class="navbar-brand" asp-area="" asp-controller="Home" asp-action="Index">LuminousStudio</a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainNavbar"
                        aria-controls="mainNavbar" aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="collapse navbar-collapse" id="mainNavbar">
                    <ul class="navbar-nav me-auto mb-2 mb-sm-0">
                        <li class="nav-item">
                            <a class="nav-link text-white" asp-area="" asp-controller="Home" asp-action="Index">Home</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-white" asp-area="" asp-controller="Home" asp-action="AboutUs">About Us</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-white" asp-area="" asp-controller="TiffanyLamp" asp-action="Index">TiffanyLamps</a>
                        </li>
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle text-white" href="#" id="lampStylesDropdown"
                                   role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                Tiffany Lamp Styles
                            </a>
                            <ul class="dropdown-menu" aria-labelledby="lampStylesDropdown">
                                <li><a class="dropdown-item" asp-area="" asp-controller="TiffanyLamp" asp-action="Index" asp-route-searchStringLampStyleName="Table Lamp">Table Lamp</a></li>
                                <li><a class="dropdown-item" asp-area="" asp-controller="TiffanyLamp" asp-action="Index" asp-route-searchStringLampStyleName="Floor Lamp">Floor Lamp</a></li>
                                <li><a class="dropdown-item" asp-area="" asp-controller="TiffanyLamp" asp-action="Index" asp-route-searchStringLampStyleName="Chandelier">Chandelier</a></li>
                                <li><a class="dropdown-item" asp-area="" asp-controller="TiffanyLamp" asp-action="Index" asp-route-searchStringLampStyleName="Wall Sconce">Wall Sconce</a></li>
                                <li><a class="dropdown-item" asp-area="" asp-controller="TiffanyLamp" asp-action="Index" asp-route-searchStringLampStyleName="Pendant Lamp">Pendant Lamp</a></li>
                                <li><a class="dropdown-item" asp-area="" asp-controller="TiffanyLamp" asp-action="Index" asp-route-searchStringLampStyleName="Ceiling Lamp">Ceiling Lamp</a></li>
                                <li><a class="dropdown-item" asp-area="" asp-controller="TiffanyLamp" asp-action="Index" asp-route-searchStringLampStyleName="Banker's Lamp">Banker's Lamp</a></li>
                            </ul>
                        </li>

                        @if (User.Identity?.IsAuthenticated == true)
                        {
                            <li class="nav-item">
                                <a class="nav-link text-white" asp-area="" asp-controller="Order" asp-action="MyOrders">My Orders</a>
                            </li>
                        }

                        <li class="nav-item">
                            <a class="nav-link text-white" asp-area="" asp-controller="Home" asp-action="Contacts">Contacts</a>
                        </li>

                        @if (User.Identity?.IsAuthenticated == true && User.IsInRole(ApplicationRoles.Administrator))
                        {
                            <li class="nav-item dropdown">
                                <a class="nav-link dropdown-toggle text-white" href="#" role="button"
                                       data-bs-toggle="dropdown" aria-expanded="false">
                                    Admin Panel
                                </a>
                                <ul class="dropdown-menu">
                                    <li>
                                        <a class="dropdown-item" asp-area="Admin"
                                               asp-controller="Home" asp-action="Index">
                                            Dashboard
                                        </a>
                                    </li>
                                    <li>
                                        <a class="dropdown-item" asp-area="Admin"
                                               asp-controller="UserManagement" asp-action="Index">
                                            Clients
                                        </a>
                                    </li>
                                    <li>
                                        <a class="dropdown-item" asp-area="Admin"
                                               asp-controller="LampManagement" asp-action="Index">
                                            Lamps
                                        </a>
                                    </li>
                                    <li>
                                        <a class="dropdown-item" asp-area="Admin"
                                               asp-controller="OrderManagement" asp-action="Index">
                                            Orders
                                        </a>
                                    </li>
                                    <li>
                                        <a class="dropdown-item" asp-area="Admin"
                                               asp-controller="Statistic" asp-action="Index">
                                            Statistics
                                        </a>
                                    </li>
                                </ul>
                            </li>
                        }
                    </ul>

                    <ul class="navbar-nav d-flex flex-row align-items-center gap-3">
                        <li class="nav-item">
                            <a class="nav-link text-white position-relative" asp-area=""
                                   asp-controller="ShoppingCart" asp-action="Index">
                                <i class="bi bi-cart"></i> Cart
                            </a>
                        </li>

                        @if (User.Identity?.IsAuthenticated == true)
                        {
                            <li class="nav-item">
                                <span class="nav-link text-white">Hello @User.Identity?.Name!</span>
                            </li>
                            <li class="nav-item">
                                <form asp-area="Identity" asp-page="/Account/Logout"
                                      method="post" class="logout-form">
                                    <button type="submit" class="btn btn-link nav-link text-white">Logout</button>
                                </form>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item">
                                <a class="nav-link text-white" asp-area="Identity" asp-page="/Account/Login">Login</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link text-white" asp-area="Identity" asp-page="/Account/Register">Register</a>
                            </li>
                        }
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="footer text-center mt-5">
        <div class="container py-1">
            <a asp-area="" asp-controller="Home" asp-action="AboutUs"
               class="text-white fs-5 mx-3">About us</a>
            <a asp-area="" asp-controller="TiffanyLamp" asp-action="Index"
               class="text-white fs-5 mx-3">Tiffany Lamps</a>
            <a asp-area="" asp-controller="Home" asp-action="Contacts"
               class="text-white fs-5 mx-3">Contacts</a>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>