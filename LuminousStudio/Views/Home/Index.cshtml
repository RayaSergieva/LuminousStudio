@{
    ViewData["Title"] = "Home Page";
}

<style>
    .video-background {
        position: fixed;
        right: 0;
        bottom: 0;
        min-width: 100%;
        min-height: 100%;
        z-index: -1;
        object-fit: cover;
    }

    .homepage-overlay {
        position: fixed;
        top: 0;
        left: 0;
        height: 100%;
        width: 100%;
        background: rgba(0, 0, 0, 0.5);
        z-index: 0;
    }

    .homepage-welcome-bar {
        position: relative;
        background-color: rgba(0, 0, 0, 0.75);
        color: white;
        padding: 3rem 1rem;
        text-align: center;
        z-index: 1;
        width: 80%;
        margin: 4rem auto;
        border-radius: 2rem;
    }

        .homepage-welcome-bar a {
            color: #ffc107;
            text-decoration: underline;
        }

        .homepage-welcome-bar p {
            font-size: 1.2rem;
            margin-top: 1rem;
        }

    body {
        margin: 0;
        padding: 0;
    }
</style>

<video autoplay muted loop class="video-background">
    <source src="~/videos/TiffanyLampsMuseumVideo.mp4" type="video/mp4">
    Your browser does not support the video tag.
</video>

<div class="homepage-overlay"></div>

<div class="homepage-welcome-bar">
    <h1 class="display-4 fw-bold">Welcome to Luminous Studio!</h1>
    <p>The premier destination for an unparalleled collection of rare and historic Tiffany lamps.</p>

    <div class="mt-3">
        <a asp-controller="TiffanyLamp" asp-action="Index"
           class="btn btn-sm fw-bold"
           style="
               background-color: #87CEFA;
               color: #000000;
               border: none;
               text-decoration: none !important;
            ">
            Explore
        </a>
    </div>
</div>
